---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="XINOK Engineering OS | RFQ DFM Manufacturing System">

<!-- ================= HERO ================= -->
<section class="section hero">
  <div class="container hero-grid">

    <!-- LEFT -->
    <div class="hero-copy">
      <div class="kicker">XINOK Engineering OS</div>

      <h1 class="h1">
        工程输入 → 自动评估 → 制造执行
      </h1>

      <p class="lead">
        RFQ · DFM · 试制 · 制造协同统一系统。<br />
        面向产品量产前的工程验证与快速试制。
      </p>

      <div class="btn-row" style="margin-top:22px;">
        <a class="btn btn-primary" href="/rfq">上传文件 / 获取报价</a>
        <a class="btn btn-secondary" href="/system">进入系统</a>
      </div>

      <div class="hero-meta">
        <div class="metric">
          <strong>72h</strong>
          <span>工程响应</span>
        </div>
        <div class="metric">
          <strong>DFM</strong>
          <span>自动结构评估</span>
        </div>
        <div class="metric">
          <strong>RFQ</strong>
          <span>报价区间生成</span>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="panel hero-stage">
      <div class="hero-stage-inner">

        <div class="kicker">SYSTEM MODULE</div>

        <div class="hero-chip-grid">
          <div class="chip">
            <b>RFQ Upload</b>
            <span>STEP / STL / PDF</span>
          </div>
          <div class="chip">
            <b>DFM Engine</b>
            <span>结构 / 工艺 / 风险</span>
          </div>
          <div class="chip">
            <b>Quote System</b>
            <span>价格区间生成</span>
          </div>
          <div class="chip">
            <b>Manufacturing</b>
            <span>CNC / 3D / 组装</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<!-- ================= CAPABILITIES ================= -->
<section class="section section-dark">
  <div class="container">

    <div class="section-title">
      <div class="kicker">SYSTEM CAPABILITY</div>
      <h2 class="h2">工程能力系统化，而不是工厂展示</h2>
    </div>

    <div class="grid-3">
      <div class="card">
        <h3 class="h3">DFM 工程分析</h3>
        <p class="muted">结构、壁厚、装配与工艺可制造性前置判断。</p>
      </div>

      <div class="card">
        <h3 class="h3">RFQ 报价系统</h3>
        <p class="muted">基于工艺路径生成价格区间与交期建议。</p>
      </div>

      <div class="card">
        <h3 class="h3">制造协同网络</h3>
        <p class="muted">CNC / SLA / SLS / 钣金 / 组装统一调度。</p>
      </div>
    </div>

  </div>
</section>

<!-- ================= WORKFLOW ================= -->
<section class="section">
  <div class="container">

    <div class="section-title">
      <div class="kicker">ENGINEERING FLOW</div>
      <h2 class="h2">从工程输入到制造交付</h2>
    </div>

    <div class="timeline">
      <div class="timeline-item">
        <span class="pill">01</span>
        <strong>上传需求</strong>
        <p>STEP / STL / PDF 或设计说明</p>
      </div>

      <div class="timeline-item">
        <span class="pill">02</span>
        <strong>DFM分析</strong>
        <p>结构 / 装配 / 工艺风险识别</p>
      </div>

      <div class="timeline-item">
        <span class="pill">03</span>
        <strong>报价生成</strong>
        <p>工艺路径 + 价格区间 + 交期</p>
      </div>

      <div class="timeline-item">
        <span class="pill">04</span>
        <strong>制造交付</strong>
        <p>生产 / 后处理 / 组装 / 出货</p>
      </div>
    </div>

  </div>
</section>

<!-- ================= INDUSTRIES ================= -->
<section class="section section-dark">
  <div class="container">

    <div class="section-title">
      <div class="kicker">APPLICATION</div>
      <h2 class="h2">面向工程验证与试制场景</h2>
    </div>

    <div class="grid-3">
      <div class="card">自动化设备</div>
      <div class="card">机器人</div>
      <div class="card">新能源装备</div>
      <div class="card">医疗设备</div>
      <div class="card">汽车零部件</div>
      <div class="card">科研院所</div>
    </div>

  </div>
</section>

<!-- ================= CTA ================= -->
<section class="section">
  <div class="container">
    <div class="panel" style="padding:28px;">

      <div class="grid-2" style="align-items:center;">
        <div>
          <div class="kicker">RFQ SYSTEM</div>
          <h2 class="h2">上传文件，进入工程评估系统</h2>
          <p class="lead">
            支持 STEP / STL / PDF。系统自动生成DFM分析与报价区间。
          </p>
        </div>

        <div class="btn-row" style="justify-content:flex-end;">
          <a class="btn btn-primary" href="/rfq">开始上传</a>
          <a class="btn btn-secondary" href="/contact">联系工程团队</a>
        </div>
      </div>

    </div>
  </div>
</section>