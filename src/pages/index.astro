---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroTech from "../components/common/HeroTech.astro";
import SectionTitle from "../components/common/SectionTitle.astro";
import Stats from "../components/common/Stats.astro";

const metrics = [
  { title: "2005+", desc: "工业工程体系起点" },
  { title: "2015+", desc: "增材制造与样机经验积累" },
  { title: "24h", desc: "工程评估响应时间" },
  { title: "1000+", desc: "工程项目协同交付" }
];

const capabilities = [
  {
    title: "工程验证（EVT / DVT / PVT）",
    desc: "围绕结构、装配、功能与制造可行性进行前置评估与风险控制，在试制阶段降低量产风险。",
    tag: "Engineering Validation"
  },
  {
    title: "试制交付（Prototype & Pilot Run）",
    desc: "支持工业样机、小批量试制与验证件生产，覆盖从打样到装配确认的完整链路。",
    tag: "Prototype Delivery"
  },
  {
    title: "制造协同（Multi-process Manufacturing）",
    desc: "整合3D打印、CNC、钣金与表面处理，实现多工艺统一交付与项目管理。",
    tag: "Manufacturing Integration"
  }
];

const workflow = [
  {
    step: "01",
    title: "提交需求（RFQ Intake）",
    text: "上传STEP/STL/PDF，明确用途、材料、交期与验证目标。"
  },
  {
    step: "02",
    title: "工程评估（DFM Review）",
    text: "分析壁厚、结构强度、公差配合、装配关系与制造风险。"
  },
  {
    step: "03",
    title: "工艺方案 & 报价（Process Plan）",
    text: "提供工艺路径对比、材料建议、成本区间与交付周期。"
  },
  {
    step: "04",
    title: "试制与交付（Build & Delivery）",
    text: "完成加工、后处理、装配、检验与工程验证交付。"
  }
];

const industries = [
  "自动化设备",
  "机器人",
  "新能源装备",
  "医疗设备",
  "汽车零部件",
  "科研院所"
];

const cases = [
  {
    title: "机器人外壳工程验证",
    meta: "2200mm / 12天",
    desc: "通过分件设计 + 装配验证，实现结构与外观同步确认并完成交付。"
  },
  {
    title: "自动化设备样机验证",
    meta: "客户验收级交付",
    desc: "同步推进结构件与装配件试制，加速客户评审与决策周期。"
  },
  {
    title: "储能设备展示级模型",
    meta: "多工艺协同",
    desc: "3D打印 + CNC + 喷涂 + 装配，实现工业级展示交付。"
  }
];

const stats = [
  { title: "SLA / SLS / SLM / FDM / FGF", desc: "增材制造体系" },
  { title: "CNC / 钣金 / 表面处理", desc: "精密加工体系" },
  { title: "Project Integration", desc: "跨工艺项目协同管理" },
  { title: "DFM Engineering", desc: "前置制造可行性评估" }
];
---

<BaseLayout
  title="VANMEE 凡觅 | 产品量产前工程验证与试制交付"
  description="VANMEE 凡觅专注产品量产前工程验证（EVT/DVT/PVT）、试制生产与多工艺制造协同交付服务。"
>

  <!-- HERO -->
  <HeroTech
    kicker="VANMEE 凡觅"
    title="产品量产前工程验证与试制交付"
    subtitle="专注EVT/DVT/PVT工程验证、试制生产与制造协同，加速产品从设计到量产落地"
    primaryHref="/upload"
    primaryLabel="上传RFQ文件"
    secondaryHref="/quote"
    secondaryLabel="获取工程评估"
    metrics={metrics}
    chips={["EVT / DVT / PVT", "DFM工程分析", "多工艺协同", "24h响应"]}
    titleRight="Engineering Validation & Manufacturing System"
  />

  <!-- PROBLEM -->
  <section class="section section-dark">
    <div class="container">
      <SectionTitle
        kicker="工程痛点"
        title="为什么产品总卡在量产前？"
        subtitle="问题不在设计，而在工程验证与制造协同"
      />

      <div class="grid-3">
        <div class="card">结构与装配缺乏验证，试制阶段才暴露问题</div>
        <div class="card">工艺路径不清晰，成本与周期不可控</div>
        <div class="card">多供应商协同困难，交付缺乏统一管理</div>
      </div>
    </div>
  </section>

  <!-- VALUE -->
  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="核心能力"
        title="工程验证驱动的制造协同系统"
        subtitle="把工程判断前移，把制造风险前置，把交付过程结构化"
      />

      <div class="grid-3">
        {capabilities.map((c) => (
          <article class="card">
            <div class="pill">{c.tag}</div>
            <h3 class="h3">{c.title}</h3>
            <p class="muted">{c.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WORKFLOW -->
  <section class="section section-dark">
    <div class="container">
      <SectionTitle
        kicker="工程流程"
        title="从RFQ到交付的工程闭环"
        subtitle="标准化工程推进路径，而不是简单加工流程"
      />

      <div class="timeline">
        {workflow.map((item) => (
          <article class="timeline-item">
            <span class="pill">{item.step}</span>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRY -->
  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="行业应用"
        title="服务产品研发与工业制造团队"
        subtitle="覆盖典型工程验证与试制场景"
      />

      <div class="grid-3">
        {industries.map((i) => (
          <div class="card">{i}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE -->
  <section class="section section-dark">
    <div class="container">
      <SectionTitle
        kicker="工程案例"
        title="案例即交付结果"
        subtitle="强调问题、方法与工程结果"
      />

      <div class="grid-3">
        {cases.map((c) => (
          <article class="card">
            <div class="badge">{c.meta}</div>
            <h3 class="h3">{c.title}</h3>
            <p class="muted">{c.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITY -->
  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="制造能力"
        title="工程与制造一体化能力体系"
        subtitle="支持复杂结构与多工艺交付"
      />

      <Stats items={stats} />
    </div>
  </section>

  <!-- RFQ -->
  <section class="section section-dark">
    <div class="container">
      <div class="panel" style="padding:28px;">
        <div class="grid-2" style="align-items:center;">
          <div>
            <div class="kicker">RFQ SYSTEM</div>
            <h2 class="h2">上传文件，获取工程评估与制造方案</h2>
            <p class="lead">
              支持STEP / STL / PDF / DWG。我们基于DFM工程分析提供工艺路径、风险评估与报价建议。
            </p>
          </div>

          <div style="justify-self:end;">
            <div class="btn-row">
              <a class="btn btn-primary" href="/upload">上传RFQ</a>
              <a class="btn btn-secondary" href="/contact">联系工程团队</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>