---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroTech from "../../components/common/HeroTech.astro";
import SectionTitle from "../../components/common/SectionTitle.astro";
import Stats from "../../components/common/Stats.astro";
const metrics = [{ title: "2005+", desc: "Industrial origin" }, { title: "2015+", desc: "Additive manufacturing" }, { title: "72h", desc: "Engineering response" }, { title: "100+", desc: "Projects coordinated" }];
const capabilities = [{ title: "Engineering Validation", desc: "Early assessment of assembly, structure, function, and manufacturability.", tag: "EVT / DVT / PVT" }, { title: "Prototype Delivery", desc: "Industrial prototypes, pilot runs, and validation samples.", tag: "Prototype / Trial Run" }, { title: "Manufacturing Coordination", desc: "CNC, 3D printing, sheet metal, finishing, and assembly.", tag: "Coordination" }];
const workflow = [{ step: "01", title: "Requirements", text: "Upload files or describe goals, materials, lead time and validation stage." }, { step: "02", title: "Engineering Review", text: "Check wall thickness, tolerance, assembly, and process risks." }, { step: "03", title: "Quotation", text: "Receive process advice, price range and next-step suggestions." }, { step: "04", title: "Delivery", text: "Production, finishing, inspection and shipment." }];
const industries = ["Automation", "Robotics", "Energy Equipment", "Medical Devices", "Automotive", "Research"];
const cases = [{ title: "Robot Enclosure Validation", meta: "2200mm / 12 days", desc: "Split-part validation and assembly coordination for structure and appearance." }, { title: "Automation Prototype", meta: "For customer acceptance", desc: "Prototype-first workflow to speed up internal and customer review." }, { title: "Energy Storage Display Model", meta: "Multi-process coordination", desc: "Printing, painting and assembly for display-level delivery." }];
const stats = [{ title: "SLA / SLS / FDM", desc: "Additive process matrix" }, { title: "CNC / Sheet Metal", desc: "Structural delivery" }, { title: "One-window", desc: "Project coordination" }, { title: "DFM", desc: "Front-loaded review" }];
---
<BaseLayout title="VANMEE | Product Engineering Validation & Smart Manufacturing" description="VANMEE focuses on engineering validation, prototype delivery and manufacturing coordination before mass production.">
  <HeroTech kicker="VANMEE" title="Product validation and pre-production delivery" subtitle="Focus on engineering validation, prototype delivery and manufacturing coordination before mass production." primaryHref="/en/upload" primaryLabel="Upload Files" secondaryHref="/en/quote" secondaryLabel="Get Quote" metrics={metrics} chips={["STEP / STL", "DFM", "Prototype Delivery", "Coordination"]} titleRight="Engineering Validation & Manufacturing OS" />
  <section class="section section-dark"><div class="container"><SectionTitle kicker="Core Value" title="We are not a single factory. We are an engineering decision and manufacturing coordination system." subtitle="Front-load engineering decisions, define manufacturing routes, and shorten delivery chains." /><div class="grid-3">{capabilities.map((c) => (<article class="card"><div class="pill">{c.tag}</div><h3 class="h3" style="margin-top:14px;">{c.title}</h3><p class="muted">{c.desc}</p></article>))}</div></div></section>
  <section class="section"><div class="container"><SectionTitle kicker="Workflow" title="Shorter path, clearer decisions." subtitle="This homepage is the starting point of the project process, not just a brochure." /><div class="timeline">{workflow.map((item) => (<article class="timeline-item"><span class="pill">{item.step}</span><strong>{item.title}</strong><p>{item.text}</p></article>))}</div></div></section>
  <section class="section section-dark"><div class="container"><SectionTitle kicker="Industries" title="Industry coverage" subtitle="Built for validation, trial production and multi-process coordination." /><div class="grid-3">{industries.map((item) => <div class="card" style="padding:18px 20px;">{item}</div>)}</div></div></section>
  <section class="section"><div class="container"><SectionTitle kicker="Cases" title="Cases prove engineering judgment." subtitle="Each case should explain problem, solution and result." /><div class="grid-3">{cases.map((item) => (<article class="card"><div class="badge" style="margin-bottom:12px;">{item.meta}</div><h3 class="h3">{item.title}</h3><p class="muted">{item.desc}</p></article>))}</div></div></section>
  <section class="section section-dark"><div class="container"><SectionTitle kicker="Capabilities" title="Manufacturing capability matrix" subtitle="Designed for prototypes, validation samples, structural parts and trial runs." /><Stats items={stats} /></div></section>
  <section class="section"><div class="container"><div class="panel" style="padding:26px;"><div class="grid-2" style="align-items:center;"><div><div class="kicker">RFQ</div><h2 class="h2">Upload files and get engineering review + quotation.</h2><p class="lead">Supports STEP, STL, PDF, sketches and project briefs. Engineers will respond based on validation goals, materials, lead time and risk.</p></div><div style="justify-self:end;"><div class="btn-row"><a class="btn btn-primary" href="/en/upload">Upload Files</a><a class="btn btn-secondary" href="/en/contact">Contact</a></div></div></div></div></div></section>
</BaseLayout>
