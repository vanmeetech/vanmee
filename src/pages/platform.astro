---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/common/SectionTitle.astro";
const layers = [["Upload Layer", "STEP / STL / PDF / brief"], ["Engineering Layer", "DFM review and process advice"], ["Pricing Layer", "Quote range and lead time"], ["Delivery Layer", "Production, finishing and shipment"]];
---
<BaseLayout title="制造协同平台 | VANMEE 凡觅" description="制造协同平台聚焦上传、工程评估、报价和交付。">
  <section class="section"><div class="container"><SectionTitle kicker="Platform" title="制造协同平台" subtitle="把上传、评估、报价、交付连接到同一个路径中。" /><div class="timeline">{layers.map((i, idx) => (<article class="timeline-item"><span class="pill">0{idx + 1}</span><strong>{i[0]}</strong><p>{i[1]}</p></article>))}</div></div></section>
</BaseLayout>
