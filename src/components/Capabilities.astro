---
const { capabilities } = Astro.props;
---
<section class="section-anchor border-b border-line/70 bg-mist py-20" id="capabilities">
  <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">{capabilities.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">{capabilities.title}</h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {capabilities.items.map((item) => (
        <article class="rounded-3xl border border-line bg-white p-6 shadow-soft">
          <h3 class="text-xl font-semibold text-navy">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slateblue">{item.text}</p>
          <p class="mt-4 text-sm text-ink"><span class="font-medium text-navy">Engineering value:</span> {item.value}</p>
        </article>
      ))}
    </div>
  </div>
</section>