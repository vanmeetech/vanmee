---
const { cases } = Astro.props;
---
<section class="section-anchor border-b border-line/70 bg-mist py-20" id="cases">
  <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">{cases.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">{cases.title}</h2>
      </div>
      <a
        href="#rfq"
        class="inline-flex items-center rounded-full border border-line bg-white px-5 py-3 text-sm font-medium text-ink transition hover:border-slateblue hover:text-navy"
      >
        {cases.action}
      </a>
    </div>
    <div class="mt-12 space-y-6">
      {cases.items.map((item) => (
        <article class="rounded-[28px] border border-line bg-white p-6 shadow-soft sm:p-8">
          <div class="grid gap-6 lg:grid-cols-[0.3fr_0.7fr]">
            <div class="rounded-3xl bg-mist p-5">
              <p class="text-sm uppercase tracking-[0.16em] text-slateblue">{item.tag}</p>
              <h3 class="mt-3 text-xl font-semibold text-navy">{item.industry}</h3>
              <ul class="mt-5 space-y-3 text-sm leading-7 text-slateblue">
                <li><span class="font-medium text-navy">Project duration:</span> {item.duration}</li>
                <li><span class="font-medium text-navy">Key process:</span> {item.process}</li>
                <li><span class="font-medium text-navy">Target:</span> {item.target}</li>
              </ul>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-line p-5">
                <p class="text-sm font-medium text-navy">Client problem</p>
                <p class="mt-3 text-sm leading-7 text-slateblue">{item.problem}</p>
              </div>
              <div class="rounded-2xl border border-line p-5">
                <p class="text-sm font-medium text-navy">Engineering solution</p>
                <p class="mt-3 text-sm leading-7 text-slateblue">{item.solution}</p>
              </div>
              <div class="rounded-2xl border border-line p-5">
                <p class="text-sm font-medium text-navy">Validation path</p>
                <p class="mt-3 text-sm leading-7 text-slateblue">{item.validation}</p>
              </div>
              <div class="rounded-2xl border border-line p-5">
                <p class="text-sm font-medium text-navy">Outcome</p>
                <p class="mt-3 text-sm leading-7 text-slateblue">{item.result}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>