---
const { trust } = Astro.props;
---
<section class="section-anchor border-b border-line/70 bg-white py-20" id="trust">
  <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">{trust.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">{trust.title}</h2>
    </div>
    <div class="mt-12 grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-6">
        {trust.boxes.map((box) => (
          <div class="rounded-3xl border border-line bg-mist p-6">
            <h3 class="text-lg font-semibold text-navy">{box.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slateblue">{box.text}</p>
            {box.subtext && <p class="mt-3 text-sm leading-7 text-slateblue">{box.subtext}</p>}
          </div>
        ))}
      </div>
      <div class="rounded-[28px] border border-line bg-white p-6 shadow-soft sm:p-8">
        <h3 class="text-2xl font-semibold text-navy">{trust.flowTitle}</h3>
        <div class="mt-8 grid gap-4">
          {trust.steps.map((step) => (
            <div class="rounded-2xl border border-line p-5">
              <p class="text-sm font-medium text-navy">{step.title}</p>
              <p class="mt-2 text-sm leading-7 text-slateblue">{step.text}</p>
            </div>
          ))}
        </div>
        <div class="mt-8 rounded-3xl bg-navy p-6 text-white">
          <h4 class="text-lg font-semibold">{trust.qualityTitle}</h4>
          <p class="mt-3 text-sm leading-7 text-white/85">{trust.qualityText}</p>
        </div>
      </div>
    </div>
  </div>
</section>