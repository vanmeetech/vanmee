---
const { pain } = Astro.props;
---
<section class="section-anchor border-b border-line/70 bg-white py-20" id="pain-points">
  <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">{pain.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">{pain.title}</h2>
      <p class="mt-5 text-base leading-8 text-slateblue">{pain.description}</p>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-5">
      {pain.items.map((item) => (
        <article class="rounded-3xl border border-line bg-mist p-6">
          <h3 class="text-lg font-semibold text-navy">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slateblue">{item.text}</p>
          <p class="mt-4 text-sm font-medium text-ink">How VANMEE responds:</p>
          <p class="mt-2 text-sm leading-7 text-slateblue">{item.solution}</p>
        </article>
      ))}
    </div>
  </div>
</section>