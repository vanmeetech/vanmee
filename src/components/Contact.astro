---
import { company } from '../data/site';
const { contact, switchHref, switchLabel, isEnglish } = Astro.props;
---
<section class="section-anchor bg-white py-20" id="contact">
  <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 xl:grid-cols-[1fr_0.9fr]">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">{contact.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">{contact.title}</h2>
        <p class="mt-5 max-w-2xl text-base leading-8 text-slateblue">{contact.description}</p>

        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div class="rounded-3xl border border-line bg-mist p-6">
            <p class="text-sm font-medium text-navy">{contact.phone}</p>
            <div class="mt-3 space-y-2 text-sm leading-7 text-slateblue">
              <p><a class="text-ink hover:text-navy" href={`tel:${company.phonePrimary.replace(/-/g, '')}`}>{company.phonePrimary}</a></p>
              <p><a class="text-ink hover:text-navy" href={`tel:${company.phoneSecondary.replace(/-/g, '')}`}>{company.phoneSecondary}</a></p>
            </div>
          </div>

          <div class="rounded-3xl border border-line bg-mist p-6">
            <p class="text-sm font-medium text-navy">{contact.email}</p>
            <p class="mt-3 text-sm leading-7 text-slateblue">
              <a class="text-ink hover:text-navy" href={`mailto:${company.email}`}>{company.email}</a>
            </p>
          </div>

          <div class="rounded-3xl border border-line bg-mist p-6 sm:col-span-2">
            <p class="text-sm font-medium text-navy">{contact.address}</p>
            <p class="mt-3 text-sm leading-7 text-slateblue">{company.address}</p>
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-line bg-mist p-6 sm:p-8">
        <div class="flex items-start justify-between gap-6">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">WeChat</p>
            <h3 class="mt-3 text-2xl font-semibold text-navy">{contact.qrTitle}</h3>
            <p class="mt-3 text-sm leading-7 text-slateblue">{contact.qrText}</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slateblue">{contact.qrBadge}</span>
        </div>

        <div class="mt-8 flex items-center justify-center rounded-[24px] border border-line bg-white p-6">
          <img
            src="/qr-wechat-placeholder.svg"
            alt={isEnglish ? 'WeChat QR placeholder' : '微信二维码占位图'}
            class="h-64 w-64 max-w-full"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<a
  href="#rfq"
  class="fixed inset-x-4 bottom-4 z-40 inline-flex items-center justify-center rounded-full bg-navy px-6 py-3.5 text-sm font-medium text-white shadow-soft transition hover:bg-ink lg:hidden"
  aria-label={isEnglish ? 'Submit project requirements' : '提交项目需求'}
>
  {isEnglish ? 'Submit Project Requirements' : '提交项目需求'}
</a>

<footer class="border-t border-line bg-white">
  <div class="mx-auto flex max-w-8xl flex-col gap-4 px-4 py-8 text-sm text-slateblue sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <p>© {new Date().getFullYear()} {isEnglish ? 'VANMEE · Engineering Validation and Manufacturing Coordination' : 'VANMEE 凡觅 · 产品工程验证与智造协同服务'}</p>
    <div class="flex items-center gap-4">
      <a href={switchHref} class="hover:text-navy">{switchLabel}</a>
      <a href="#rfq" class="hover:text-navy">{isEnglish ? 'RFQ Review' : 'RFQ 预评估'}</a>
    </div>
  </div>
</footer>
