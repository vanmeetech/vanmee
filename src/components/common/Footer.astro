---
const pathname = Astro.url.pathname;
const isEn = /^\/en(\/|$)/.test(pathname);
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h3>VANMEE 凡觅</h3>
        <p class="muted">产品工程验证与智造服务商<br />让创新产品更快落地</p>
        <p class="small">南昌高新开发区火炬大街89号<br />support@vanmee.cn<br />0791-8811 1566</p>
      </div>
      <div><h4>{isEn ? "Navigation" : "导航"}</h4><ul class="list-check"><li><a href={isEn ? "/en/" : "/"}>{isEn ? "Home" : "首页"}</a></li><li><a href={isEn ? "/en/solutions" : "/solutions"}>{isEn ? "Solutions" : "解决方案"}</a></li><li><a href={isEn ? "/en/capabilities" : "/capabilities"}>{isEn ? "Capabilities" : "制造能力"}</a></li><li><a href={isEn ? "/en/case-studies" : "/case-studies"}>{isEn ? "Cases" : "案例"}</a></li></ul></div>
      <div><h4>{isEn ? "Services" : "核心服务"}</h4><ul class="list-check"><li>{isEn ? "Engineering validation" : "工程验证"}</li><li>{isEn ? "Prototype delivery" : "试制交付"}</li><li>{isEn ? "Manufacturing coordination" : "制造协同"}</li><li>{isEn ? "Supply chain integration" : "供应链整合"}</li></ul></div>
      <div><h4>{isEn ? "Contact" : "联系"}</h4><p class="small">www.vanmee.cn<br />support@vanmee.cn</p></div>
    </div>
  </div>
</footer>
