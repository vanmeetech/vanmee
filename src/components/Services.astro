---
const { services } = Astro.props;
---
<section class="section-anchor border-b border-line/70 bg-mist py-20" id="services">
  <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-slateblue">{services.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">{services.title}</h2>
      </div>
      <a
        href="#rfq"
        class="inline-flex items-center rounded-full border border-line bg-white px-5 py-3 text-sm font-medium text-ink transition hover:border-slateblue hover:text-navy"
      >
        {services.action}
      </a>
    </div>
    <div class="mt-12 grid gap-6 lg:grid-cols-2 2xl:grid-cols-4">
      {services.items.map((item) => (
        <article class="flex h-full flex-col rounded-3xl border border-line bg-white p-6 shadow-soft">
          <h3 class="text-xl font-semibold text-navy">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slateblue">{item.text}</p>
          <div class="mt-5 space-y-3 text-sm text-ink">
            <p><span class="font-medium text-navy">Best for:</span> {item.scenario}</p>
            <p><span class="font-medium text-navy">What it reduces:</span> {item.reduce}</p>
          </div>
          <div class="mt-6 pt-6">
            <a href="#rfq" class="text-sm font-medium text-navy underline decoration-line underline-offset-4">{item.cta}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>